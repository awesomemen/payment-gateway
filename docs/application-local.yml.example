# application-local.yml
# 本地开发配置，不提交到仓库
# 对应 docker/local-compose.yml 中的服务端口

spring:
  datasource:
    url: jdbc:mysql://localhost:${GATEWAY_MYSQL_PORT:3307}/gateway_db?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: gateway
    password: gateway_local_pass
    driver-class-name: com.mysql.cj.jdbc.Driver

  data:
    redis:
      host: localhost
      port: 6379
      password: local_redis_pass
      timeout: 3000ms

  cloud:
    nacos:
      discovery:
        server-addr: localhost:8848
        namespace: local
        health-indicator:
          enabled: true
      config:
        server-addr: localhost:8848
        namespace: local
        file-extension: json
        health-indicator:
          enabled: true

rocketmq:
  name-server: localhost:9876
  producer:
    group: gateway-producer-local
  consumer:
    group: gateway-consumer-local

seata:
  enabled: true
  application-id: gateway-service
  tx-service-group: gateway-tx-group
  service:
    vgroup-mapping:
      gateway-tx-group: default
  registry:
    type: file
  config:
    type: file

dubbo:
  registry:
    address: nacos://localhost:8848
  protocol:
    name: dubbo
    port: 20880

# SkyWalking Agent 通过 JVM 参数注入，不在此配置
# 启动时添加：-javaagent:/path/to/skywalking-agent.jar
# -Dskywalking.agent.service_name=gateway-service
# -Dskywalking.collector.backend_service=localhost:11800

gateway:
  security:
    config-source: application-local
  downstream:
    sandbox:
      enabled: true
    request-expire-seconds: 300
    replay-protect-seconds: 300
    merchants:
      MCH100001:
        enabled: true
        signature-key: demo-signature-key
  persistence:
    mode: jdbc
  idempotency:
    expire-seconds: 86400
    lock-wait-millis: 0
    lock-lease-seconds: 10
  governance:
    enabled: true
    backend: redis
    config-source: nacos
    permits-per-minute: 60
  reconcile:
    enabled: true
    processing-limit: 20
    processing-cron: "0/30 * * * * *"
  messaging:
    rocketmq:
      enabled: false
      topic: gateway-payment-events
      tag: PAYMENT_CREATED
      retry-enabled: true
      retry-limit: 20
      retry-delay-seconds: 300
      retry-cron: "0 */1 * * * *"
    notification:
      enabled: true
      retry-limit: 20
      max-consume-retries: 3
      retry-cron: "0 */1 * * * *"
      consumer-group: gateway-consumer-local
